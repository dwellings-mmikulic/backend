# Database — for local non-Docker runs. In docker compose this is set automatically.
DATABASE_URL=postgres://dwellings:dwellings@localhost:5432/dwellings?sslmode=disable

# Scheduler — standard 5-field cron expression (default: hourly).
CRON_SCHEDULE=0 * * * *

# OpenWebNinja Real-Time Zillow Data API
ZILLOW_BASE_URL=https://api.openwebninja.com/realtime-zillow-data
ZILLOW_API_KEY=

# Leave already-stored listings (by zpid) untouched — no re-upsert or re-render.
# Set to false to refresh existing listings (price, photos) each cycle.
SKIP_EXISTING=true

# Images — set to false to skip Bunny upload and store source Zillow URLs directly
# (handy for local/dev runs; Bunny vars below are only required when true).
IMAGES_ENABLED=true

# Bunny CDN storage
BUNNY_STORAGE_ZONE=
BUNNY_API_KEY=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_CDN_BASE_URL=https://your-zone.b-cdn.net

# Search criteria
SEARCH_LOCATION=Punta Gorda, FL
SEARCH_HOME_STATUS=FOR_SALE
SEARCH_MIN_PRICE=0
SEARCH_MAX_PRICE=0
SEARCH_MIN_BEDROOMS=0
SEARCH_MAX_RESULTS=50

# Video rendering (Roku listing videos)
VIDEO_ENABLED=true
VIDEO_SECONDS_PER_PHOTO=4
MUSIC_DIR=assets/music
# Font for overlay text. In Docker this defaults to the bundled DejaVu font.
VIDEO_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSans-Bold.ttf

# HTTP server (Roku Direct Publisher feed at /roku/feed.json, plus /healthz)
HTTP_PORT=8080

# Concurrency. Renders are CPU-bound (defaults to CPU count); image downloads/
# uploads are I/O-bound. Lower LISTING_CONCURRENCY on small machines.
LISTING_CONCURRENCY=
IMAGE_CONCURRENCY=8

# Outbound HTTP timeout (seconds) for Zillow + image downloads
HTTP_TIMEOUT_SECONDS=30
# Bunny upload timeout (seconds) — large for big video files
BUNNY_TIMEOUT_SECONDS=300
